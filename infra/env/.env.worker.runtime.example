# Worker-only local runtime. Never use bootstrap/root credentials here.
EVIDENCE_LOOP_ENV=local
SYNTHETIC_DATA_ONLY=true
DATABASE_URL=postgresql://evidence_loop_worker:GENERATE_LOCALLY_POSTGRES_WORKER_PASSWORD@postgres:5432/evidence_loop
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=GENERATE_LOCALLY_MINIO_WORKER_ACCESS_KEY
S3_SECRET_ACCESS_KEY=GENERATE_LOCALLY_MINIO_WORKER_SECRET_KEY
S3_BUCKET_QUARANTINE=quarantine
S3_BUCKET_CLEAN=clean
S3_BUCKET_DERIVED=derived
# Worker-only Unix-domain ClamAV socket and read-only signature data; no scanner TCP port is exposed.
CLAMD_SOCKET=/run/clamav/clamd.sock
CLAMD_SIGNATURE_DIRECTORY=/var/lib/clamav
# A missing, unreadable, or older database blocks processing rather than trusting clamd OK.
CLAMD_MAX_SIGNATURE_AGE_SECONDS=86400

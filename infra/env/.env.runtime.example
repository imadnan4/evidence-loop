# Runtime-only local API environment. Generate with scripts/create-local-env.mjs.
# It intentionally excludes bootstrap and migration credentials.
EVIDENCE_LOOP_ENV=local
SYNTHETIC_DATA_ONLY=true
PORT=3001
DATABASE_URL=postgresql://evidence_loop_app:GENERATE_LOCALLY_POSTGRES_APP_PASSWORD@postgres:5432/evidence_loop
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=GENERATE_LOCALLY_MINIO_API_ACCESS_KEY
S3_SECRET_ACCESS_KEY=GENERATE_LOCALLY_MINIO_API_SECRET_KEY
S3_BUCKET_QUARANTINE=quarantine
S3_BUCKET_CLEAN=clean
S3_BUCKET_DERIVED=derived
OIDC_ISSUER=http://127.0.0.1:9100
OIDC_JWKS_URI=http://127.0.0.1:9100/jwks
OIDC_AUDIENCE=evidence-loop-api
OIDC_ORGANIZATION_CLAIM=https://evidence-loop.test/organization_id
ALLOWED_WEB_ORIGINS=http://127.0.0.1:3000
DEPLOYMENT_ID=local
RELEASE_VERSION=dev

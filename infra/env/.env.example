# Privileged local bootstrap/migration environment. Generate with scripts/create-local-env.mjs.
# Never mount this file into API or worker containers.
EVIDENCE_LOOP_ENV=local
SYNTHETIC_DATA_ONLY=true

POSTGRES_USER=evidence_loop
POSTGRES_PASSWORD=GENERATE_LOCALLY_POSTGRES_PASSWORD
POSTGRES_DB=evidence_loop
POSTGRES_PORT=5432
POSTGRES_APP_USER=evidence_loop_app
POSTGRES_APP_PASSWORD=GENERATE_LOCALLY_POSTGRES_APP_PASSWORD

MINIO_ROOT_USER=GENERATE_LOCALLY_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=GENERATE_LOCALLY_MINIO_PASSWORD
MINIO_API_PORT=9000
S3_BUCKET_QUARANTINE=quarantine
S3_BUCKET_CLEAN=clean
S3_BUCKET_DERIVED=derived

# Copy with `node scripts/create-local-env.mjs`; this file is not deployable.
EVIDENCE_LOOP_ENV=local
SYNTHETIC_DATA_ONLY=true
PORT=3001

POSTGRES_USER=evidence_loop
POSTGRES_PASSWORD=GENERATE_LOCALLY_POSTGRES_PASSWORD
POSTGRES_DB=evidence_loop
POSTGRES_PORT=5432
DATABASE_URL=postgresql://evidence_loop:GENERATE_LOCALLY_POSTGRES_PASSWORD@127.0.0.1:5432/evidence_loop

MINIO_ROOT_USER=GENERATE_LOCALLY_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=GENERATE_LOCALLY_MINIO_PASSWORD
MINIO_API_PORT=9000
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=GENERATE_LOCALLY_MINIO_ACCESS_KEY
S3_SECRET_ACCESS_KEY=GENERATE_LOCALLY_MINIO_PASSWORD
S3_BUCKET_QUARANTINE=quarantine
S3_BUCKET_CLEAN=clean
S3_BUCKET_DERIVED=derived

ALLOWED_WEB_ORIGINS=http://127.0.0.1:3000
DEPLOYMENT_ID=local
RELEASE_VERSION=dev
